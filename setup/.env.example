# env template — copy to ~/.openclaw/.env and fill in your keys
# DO NOT commit this file to Git!

# ── AI Brain (Required) ─────────────────────────────────────
# Get from: https://platform.deepseek.com/api_keys
# Free trial credits on signup, then very cheap (~$0.001 per message)
DEEPSEEK_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Voice Notes (Optional) ──────────────────────────────────
# Needed ONLY for WhatsApp voice note transcription (Whisper)
# Get from: https://platform.openai.com/api-keys
# Cost: ~$0.006/minute — a few cents/month for personal use
# If you skip this, voice notes won't be transcribed
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── WhatsApp (Your phone number, used by OpenClaw to restrict incoming commands)
# Use international format with plus sign, e.g. +923036039298
WHATSAPP_NUMBER=+923036039298
